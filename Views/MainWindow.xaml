<Window x:Class="AiWebsiteBuilder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="AI Website Builder - Launch Panel"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#020617"
        Foreground="#F8FAFC"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155" />
                                <Setter Property="BorderBrush" Value="#475569" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F172A" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Modern Fluent Header -->
        <Border Grid.Row="0" Background="#020617" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,16,0">
                        <Border Width="40" Height="40" Background="#3B82F6" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#3B82F6" Opacity="0.3" ShadowDepth="0" />
                            </Border.Effect>
                        </Border>
                        <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" />
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="AI WEBSITE BUILDER" FontSize="14" FontWeight="Black" Foreground="#F8FAFC" LetterSpacing="2" />
                        <TextBlock Text="v1.0 • .NET HYBRID CORE" FontSize="10" Foreground="#64748B" FontWeight="Bold" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="ConfigButton" Click="ConfigButton_Click" Margin="0,0,8,0"
                            Style="{StaticResource ModernButton}" Content="CONFIG" />
                    <Button Name="RefreshButton" Click="RefreshButton_Click" Margin="0,0,8,0"
                            Style="{StaticResource ModernButton}" Content="RELOAD" />
                    <Button Name="DevToolsButton" Click="DevToolsButton_Click" 
                            Style="{StaticResource ModernButton}" Content="INSPECT" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- WebView2 Container -->
        <Border Grid.Row="1" Background="#020617">
            <Grid>
                <wv2:WebView2 x:Name="WebView" />
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#22C55E" Opacity="0.5" ShadowDepth="0" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Name="StatusText" Text="CONNECTED TO NEXT.JS"
                               Foreground="#94A3B8" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1" Name="AppVersionText" Text="CLR RUNTIME ACTIVE"
                           Foreground="#475569" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" Name="LoadingOverlay" Background="#020617" Visibility="Visible" Panel.ZIndex="1000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="60" Height="60" Margin="0,0,0,24">
                    <Ellipse Stroke="#1E293B" StrokeThickness="4" />
                    <Ellipse Stroke="#3B82F6" StrokeThickness="4" StrokeDashArray="1,2" Name="SpinnerCircle">
                        <Ellipse.RenderTransform>
                            <RotateTransform CenterX="30" CenterY="30" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>

                <TextBlock Text="AI WEBSITE BUILDER" TextAlignment="Center"
                           FontSize="14" FontWeight="Black" Foreground="#F8FAFC" LetterSpacing="4" Margin="0,0,0,8" />
                <TextBlock Name="LoadingText" Text="INITIALIZING HYBRID ENVIRONMENT..." TextAlignment="Center"
                           FontSize="10" Foreground="#64748B" FontWeight="Bold" />

                <ProgressBar Margin="0,32,0,0" Width="200" Height="2" Background="#1E293B" Foreground="#3B82F6"
                             IsIndeterminate="True" BorderThickness="0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
